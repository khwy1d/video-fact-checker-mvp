# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# احصل عليه من: https://neon.tech → Project → Connection String
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-random-secret-here-min-32-chars

# ─── Manus OAuth (اتركها فارغة إذا لم تستخدم Manus) ──────────────────────────
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ─── LLM API ──────────────────────────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Frontend (Vercel) ────────────────────────────────────────────────────────
# عنوان الـ Backend على Render
VITE_API_URL=https://video-fact-checker-api.onrender.com
